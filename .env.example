# Accesco Living IMS Environment Variables

# App Config
PROJECT_NAME="Accesco Living IMS"
API_V1_STR="/api/v1"
DEBUG=true

# Security
JWT_SECRET_KEY="supersecretkeythatisverylongandsecurechangeinproduction"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
# Use localhost for local dev and postgres for docker-compose
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/accesco_ims"

# Redis
# Use localhost for local dev and redis for docker-compose
REDIS_URL="redis://localhost:6379/0"

# Kafka
# Use localhost:9092 for local dev and kafka:9092 for docker-compose
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_mockkeyid123"
RAZORPAY_KEY_SECRET="mockkeysecret456"
RAZORPAY_WEBHOOK_SECRET="mockwebhooksecret789"
