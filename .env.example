# ==============================================================
# Accesco Living IMS — Environment Variables
# ==============================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
# ==============================================================

# ---- App Config ----
PROJECT_NAME="Accesco Living IMS"
API_V1_STR="/api/v1"
DEBUG=true

# ---- Security ----
JWT_SECRET_KEY="supersecretkeythatisverylongandsecurechangeinproduction"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Database ----
# Local development (Python running on host):
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/accesco_ims"
# Docker Compose (uncomment this, comment out the line above):
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@postgres:5432/accesco_ims"

# ---- Redis ----
# Local development (Python running on host):
REDIS_URL="redis://localhost:6379/0"
# Docker Compose (uncomment this, comment out the line above):
# REDIS_URL="redis://redis:6379/0"

# ---- Kafka ----
# Local development (Python running on host):
KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
# Docker Compose (uncomment this, comment out the line above):
# KAFKA_BOOTSTRAP_SERVERS="kafka:29092"

# ---- Razorpay ----
RAZORPAY_KEY_ID="rzp_test_mockkeyid123"
RAZORPAY_KEY_SECRET="mockkeysecret456"
RAZORPAY_WEBHOOK_SECRET="mockwebhooksecret789"

# ---- Docker Entrypoint Config ----
# Set to "true" to seed the database on container startup (first run)
# RUN_SEED=true
